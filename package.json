{
  "name": "@ngotrnghia1811/opencode-headroom",
  "version": "0.1.3",
  "description": "Context compression plugin for opencode — port of headroom with Kneedle adaptive-K, BM25 relevance scoring, and CCR reversibility",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/index.ts"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "context-compression",
    "token-reduction",
    "llm",
    "headroom"
  ],
  "author": "ngotrnghia1811",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ngotrnghia1811/opencode-headroom.git"
  },
  "homepage": "https://github.com/ngotrnghia1811/opencode-headroom#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "dependencies": {
    "@ngotrnghia1811/opencode-headroom": "^0.1.3",
    "js-tiktoken": "^1.0.19"
  },
  "optionalDependencies": {
    "@xenova/transformers": ">=2.0.0",
    "onnxruntime-node": "^1.26.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "scripts": {
    "test": "bun test --timeout 30000",
    "typecheck": "bun build src/index.ts --target=bun --outfile=/dev/null --external '@xenova/*' --external 'onnxruntime-node'"
  }
}
